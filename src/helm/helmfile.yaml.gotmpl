environments:
  dev:
    values:
      - version: 0.0.1
  dev-proconnect:
    values:
      - version: 0.0.1

---
repositories:
- name: dev-backends
  url: https://suitenumerique.github.io/helm-dev-backend
---

releases:
  - name: dev-backend
    namespace: {{ .Namespace }}
    chart: dev-backends/dev-backend
    version: 0.0.4
    values:
      - env.d/common/values.dev-backend.yaml.gotmpl

  - name: conversations
    version: {{ .Values.version }}
    namespace: {{ .Namespace }}
    chart: ./conversations
    values:
      - env.d/common/values.conversations.yaml.gotmpl
      - env.d/{{ .Environment.Name }}/values.oidc.yaml.gotmpl
