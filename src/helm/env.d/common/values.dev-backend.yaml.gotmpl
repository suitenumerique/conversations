postgres:
  enabled: true
  name: postgres
  serviceNameOverride: postgres
  image: postgres:16-alpine
  username: dinum
  password: pass
  database: conversations
  size: 1Gi
redis:
  enabled: true
  name: redis
  image: redis:8.2-alpine
  username: user
  password: pass
minio:
  enabled: true
  image: minio/minio
  name: minio
  serviceNameOverride: minio
  ingress:
    enabled: true
    hostname: conversations-minio.127.0.0.1.nip.io
    tls:
      enabled: true
      secretName: conversations-tls
  consoleIngress:
    enabled: true
    hostname: conversations-minio-console.127.0.0.1.nip.io
    tls:
      enabled: true
      secretName: conversations-tls
  username: dinum
  password: password
  bucket: conversations-media-storage
  versioning: true
  size: 1Gi
keycloak:
  enabled: true
  image: quay.io/keycloak/keycloak:20.0.1
  name: keycloak
  #serviceNameOverride: keycloak
  hostname: conversations-keycloak.127.0.0.1.nip.io
  username: admin
  password: pass
  tls:
    enabled: true
    secretName: conversations-tls
  db:
    username: dinum
    password: pass
    database: keycloak
    size: 1Gi
    image: postgres:16-alpine
  realm: 
    name: conversations
    username: conversations
    password: conversations
    email: conversations@example.com

